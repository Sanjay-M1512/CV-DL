      "Mean = 5.0\n",
      "Variance = 5.0\n"
     ]
    }
   ],
   "source": [
    "X = [2, 4, 6, 8]\n",
    "\n",
    "mean = sum(X) / len(X)\n",
    "variance = sum((x - mean) ** 2 for x in X) / len(X)\n",
    "\n",
    "print(f\"Mean = {mean}\")\n",
    "print(f\"Variance = {variance}\")"
   ]
  }
