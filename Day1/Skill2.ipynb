   "source": [
    "import numpy as np\n",
    "\n",
    "def sigmoid(z): \n",
    "    return 1 / (1 + np.exp(-z))\n",
    "\n",
    "a=sigmoid(1)\n",
    "b=sigmoid(-1)\n",
    "\n",
    "print(\"Correct Sigmoid:\", a)\n",
    "print(\"Incorrect Sigmoid:\", b)"
   ]
