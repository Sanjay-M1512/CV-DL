      "Linear Combination (z): 5.551115123125783e-17\n",
      "ReLU Output: 5.551115123125783e-17\n"
     ]
    }
   ],
   "source": [
    "import numpy as np\n",
    "\n",
    "def relu(z): \n",
    "    return max(0, z)\n",
    "\n",
    "x = np.array([2.0, -1.0])\n",
    "w = np.array([0.4, 0.6])\n",
    "b = -0.2\n",
    "\n",
    "z = np.dot(x, w) + b\n",
    "print(\"Linear Combination (z):\", z)\n",
    "print(\"ReLU Output:\", relu(z))\n"
   ]
  }
