    "import numpy as np\n",
    "\n",
    "w=0.5\n",
    "n=0.1\n",
    "dw=0.2\n",
    "nn=1\n",
    "g= w - n * dw\n",
    "gn= w - nn * dw\n",
    "print(\"Updated weight :\", round(g, 2))\n",
    "print(\"Updated weight (nn):\", round(gn, 2))\n"
