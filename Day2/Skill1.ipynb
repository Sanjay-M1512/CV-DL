   ],
   "source": [
    "import numpy as np\n",
    "actual = 1\n",
    "pred = 0.8\n",
    "\n",
    "MSE = (pred - actual) ** 2\n",
    "Entropy = - (actual * np.log(pred) + (1 - actual) * np.log(1 - pred))\n",
    "\n",
    "print(\"Mean Squared Error:\", round(MSE, 2))\n",
    "print(\"Entropy:\", round(Entropy, 4))"
   ]
  }
