   "source": [
    "import numpy as np\n",
    "\n",
    "X = np.array([2.0, 3.0])\n",
    "W = np.array([0.5, -0.4])\n",
    "b = 1.0\n",
    "\n",
    "Z = np.dot(X, W) + b\n",
    "relu = np.maximum(0, Z)\n",
    "\n",
    "print(\"Z:\", round(Z,1))\n",
    "print(\"ReLU activation:\", round(relu,1))"
   ]
  }
 ],
